  <metadata>
    <id>pstop</id>
    <version>0.3.5</version>
    <title>pstop - htop for Windows</title>
    <authors>marlocarlo</authors>
    <owners>marlocarlo</owners>
    <projectUrl>https://github.com/marlocarlo/pstop</projectUrl>
    <licenseUrl>https://github.com/marlocarlo/pstop/blob/master/LICENSE</licenseUrl>
    <iconUrl>https://cdn.jsdelivr.net/gh/marlocarlo/pstop@master/icon.png</iconUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
